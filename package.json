{
  "name": "agent-tools",
  "version": "1.0.0",
  "description": "High-performance CLI and MCP server for video, audio, PDF, and file conversion designed for AI models and command line usage.",
  "main": "./dist/index.cjs",
  "type": "module",
  "bin": {
    "agent-tools": "./dist/index.cjs"
  },
  "scripts": {
    "build": "tsc",
    "bundle": "esbuild src/index.ts --bundle --platform=node --target=node22 --outfile=dist/index.cjs --packages=external",
    "package": "npm run build && npm run bundle && npx @yao-pkg/pkg . --targets node22-win-x64 --output agent-tools.exe",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "jest"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "cli",
    "video-editor",
    "audio-editor",
    "pdf-tools",
    "converter",
    "ai-tools"
  ],
  "author": "Ritesh Raj Arul Selvan",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.1",
    "adm-zip": "^0.5.17",
    "commander": "^12.1.0",
    "fluent-ffmpeg": "^2.1.3",
    "fonteditor-core": "^2.6.3",
    "google-tts-api": "^2.0.2",
    "node-qpdf": "^1.0.3",
    "pdf-lib": "^1.17.1",
    "pdfreader": "^3.0.8",
    "sharp": "^0.33.5",
    "tar": "^7.5.16"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/fluent-ffmpeg": "^2.1.27",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.11.24",
    "@types/tar": "^6.1.13",
    "esbuild": "^0.28.1",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.11",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3"
  },
  "pkg": {
    "assets": [
      "node_modules/@img/sharp-win32-x64/**/*"
    ]
  }
}